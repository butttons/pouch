{
  "name": "pouch",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler types && wrangler build",
    "deploy": "wrangler types && wrangler deploy",
    "cf-typegen": "wrangler types",
    "type-check": "tsc",
    "test": "vitest run",
    "generate-test-migrations": "tsx scripts/generate-test-migrations.ts",
    "db:generate": "drizzle-kit generate --config=./src/lib/db/config.dev.ts",
    "db:migrate": "wrangler d1 migrations apply pouch --local",
    "db:migrate:prod": "wrangler d1 migrations apply pouch",
    "db:codegen": "dotenv -e .env -- drizzle-kit migrate --config=./src/lib/db/config.dev.ts && DATABASE_URL='./pouch.db' kysely-codegen --dialect sqlite --out-file ./src/lib/db/types.ts --exclude-pattern=__drizzle_migrations"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.9.9",
    "json-diff-ts": "^4.10.4",
    "kysely": "^0.27.6",
    "kysely-d1": "^0.3.0",
    "neverthrow": "^8.2.0",
    "typebox": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "22.13.0",
    "@types/service-worker-mock": "^2.0.4",
    "better-sqlite3": "^11.8.1",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.24.2",
    "kysely-codegen": "^0.17.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.1"
  }
}
