{
  "name": "@butttons/pouch",
  "version": "0.0.27",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler types && wrangler build",
    "deploy": "pnpm run db:migrate:prod && wrangler types && wrangler deploy",
    "cf-typegen": "wrangler types",
    "type-check": "tsc",
    "test": "vitest run",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check",
    "generate-test-migrations": "tsx scripts/generate-test-migrations.ts",
    "db:generate": "drizzle-kit generate --config=./src/lib/db/config.dev.ts",
    "db:migrate": "wrangler d1 migrations apply pouch-cms --local",
    "db:migrate:prod": "wrangler d1 migrations apply pouch-cms --remote",
    "db:codegen": "drizzle-kit migrate --config=./src/lib/db/config.dev.ts && DATABASE_URL='./pouch.db' kysely-codegen --dialect sqlite --out-file ./src/lib/db/types.ts --exclude-pattern=__drizzle_migrations"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.11.11",
    "hono": "^4.12.31",
    "json-diff-ts": "^4.10.4",
    "kysely": "^0.27.6",
    "neverthrow": "^8.2.0",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "22.13.0",
    "@types/service-worker-mock": "^2.0.4",
    "better-sqlite3": "^11.8.1",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "kysely-codegen": "^0.17.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.1"
  },
  "cloudflare": {
    "bindings": {
      "JWT_SECRET": {
        "description": "Generate a strong secret and keep it safe (`openssl rand -hex 32`). You will need it to create API keys."
      },
      "DOCS_SECRET": {
        "description": "Password for the `/docs` Scalar API reference endpoint."
      },
      "MEDIA_PUBLIC_URL": {
        "description": "Public base URL for serving uploaded media files."
      },
      "MEDIA_BUCKET": {
        "description": "R2 bucket for storing uploaded media files."
      },
      "MCP_ADMIN_PASSPHRASE": {
        "description": "MCP Admin password."
      }
    }
  }
}
